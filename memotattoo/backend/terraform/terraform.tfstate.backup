            "template_id": "memotattoo-refine-image-v1",
            "template_string": "name: memotattoo-refine-image-v1\nmodel: gemini-3.1-flash-image-preview\ninput:\n  schema:\n    inline_image?(object, inline image data):\n      type: object\n      properties:\n        mime_type: string\n        contents: string\n    modification_prompt: string\n---\n{{role \"user\"}}\nModify the following reference image strictly based on these instructions:\n{{modification_prompt}}\n\n{{#if inline_image}}\n  {{media type=inline_image.mime_type data=inline_image.contents}}\n{{/if}}\n",
            "timeouts": null,
