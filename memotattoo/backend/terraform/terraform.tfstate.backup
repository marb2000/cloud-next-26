      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "create_time": "2026-03-05T00:29:14.516847Z",
            "display_name": "memotattoo-brainstorm-more-v1",
            "id": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-brainstorm-more-v1",
            "location": "us-central1",
            "locked": false,
            "model": "",
            "name": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-brainstorm-more-v1",
            "project": "ai-logic-demos",
            "state_change_time": "2026-03-05T00:29:14.516847Z",
            "template_id": "memotattoo-brainstorm-more-v1",
            "template_string": "model: \"gemini-2.5-flash\"\ninput:\n  schema:\n    topic:\n      type: \"string\"\n    existing_terms:\n      type: \"string\"\n---\n{{role \"system\"}}\nYou are an educational assistant building a curriculum deck about \"{{topic}}\". \n\n{{role \"user\"}}\nThe user already has the following terms: [{{existing_terms}}]. \nGenerate exactly 3 MORE new, unique terms and definitions that are highly relevant but NOT duplicates of the existing terms. \nReturn strictly as a raw JSON array of objects with 'term' and 'definition' keys. Do not use markdown code blocks. Do not include any other text.\n",
            "timeouts": null,
            "update_time": "2026-03-06T23:39:10.622907Z"
          },
          "sensitive_attributes": [],
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxMjAwMDAwMDAwMDAwLCJkZWxldGUiOjEyMDAwMDAwMDAwMDAsInVwZGF0ZSI6MTIwMDAwMDAwMDAwMH19"
        }
      ]
    },
    {
      "mode": "managed",
      "type": "google_firebase_ai_logic_prompt_template",
      "name": "generate_concept",
      "provider": "provider[\"registry.terraform.io/hashicorp/google-beta\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "create_time": "2026-03-03T00:20:15.168015Z",
            "display_name": "MemoTattoo-Generate-Concept-Image-v1",
            "id": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-generate-concept-image-v1",
            "location": "us-central1",
            "locked": false,
            "model": "",
            "name": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-generate-concept-image-v1",
            "project": "ai-logic-demos",
            "state_change_time": "2026-03-03T00:20:15.168015Z",
            "template_id": "memotattoo-generate-concept-image-v1",
            "template_string": "model: \"gemini-3.1-flash-image-preview\"\ninput:\n  schema:\n    title:\n      type: \"string\"\n    term:\n      type: \"string\"\n    definition:\n      type: \"string\"\n    art_direction:\n      type: \"string\"\n    art_reference_image?(object, inline image data):\n      type: object\n      properties:\n        mime_type: string\n        contents: string\n---\n{{role \"user\"}}\nGenerate a single image illustrating the following concept:\n\nTerm: {{term}}\nContext/Definition: {{definition}}\n\nThis concept belongs to the broader topic of: \"{{title}}\".\nDraw a perfect and simple visual representation for this term, keeping the core theme in mind.\n\nSTRICT NEGATIVE PROMPT:\n- Do not generate any written words, letters, labels, text bubbles, numbering badges, captions, or watermarks whatsoever.\n- Do not create comic book panels or grids. The image must be a single cohesive scene or subject.\n\nAdditional User Art Direction (if provided):\n{{art_direction}}\n\n{{#if art_reference_image}}\nFollow the exact aesthetic, color palette, and visual style of this reference image:\n  {{media type=art_reference_image.mime_type data=art_reference_image.contents}}\n{{/if}}\n",
            "timeouts": null,
            "update_time": "2026-03-06T23:39:10.456353Z"
          },
          "sensitive_attributes": [],
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxMjAwMDAwMDAwMDAwLCJkZWxldGUiOjEyMDAwMDAwMDAwMDAsInVwZGF0ZSI6MTIwMDAwMDAwMDAwMH19"
        }
      ]
    },
    {
      "mode": "managed",
      "type": "google_firebase_ai_logic_prompt_template",
      "name": "generate_topic",
      "provider": "provider[\"registry.terraform.io/hashicorp/google-beta\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "create_time": "2026-02-26T05:50:42.245087Z",
            "display_name": "MemoTattoo-Generatate-Topic-v1",
            "id": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-generatate-topic-v1",
            "location": "us-central1",
            "locked": false,
            "model": "",
            "name": "projects/ai-logic-demos/locations/us-central1/templates/memotattoo-generatate-topic-v1",
            "project": "ai-logic-demos",
            "state_change_time": "2026-02-26T05:50:42.245087Z",
            "template_id": "memotattoo-generatate-topic-v1",
            "template_string": "model: \"gemini-1.5-flash\"\nconfig:\n  temperature: 0.3\ninput:\n  schema:\n    topic:\n      type: \"string\"\n      description: \"The subject or phrasal verb to visualize (e.g., 'Kitchen Utensils', 'Come across', 'Newton's Laws')\"\n    numConcepts:\n      type: \"integer\"\n      description: \"The number of items to generate\"\n      default: 10\noutput:\n  format: \"json\"\n  schema:\n    type: \"object\"\n    required: [title, layout_style, items]\n    properties:\n      title:\n        type: \"string\"\n        description: \"A clean, accurate title for the topic\"\n      layout_style:\n        type: \"string\"\n        enum: [\"Flat-Lay\", \"Comic-Grid\", \"Diagram-Grid\"]\n        description: \"Flat-Lay (objects), Comic-Grid (actions/verbs), or Diagram-Grid (abstract/science)\"\n      items:\n        type: \"array\"\n        items:\n          type: \"object\"\n          required: [number, term, definition]\n          properties:\n            number:\n              type: \"integer\"\n              minimum: 1\n              maximum: 20\n            term:\n              type: \"string\"\n              description: \"The name of the item, action, or concept\"\n            definition:\n              type: \"string\"\n              description: \"A short explanation for the app UI, explaining what this concept means.\"\n---\n{{role \"system\"}}\nYou are an Educational Data API. Your job is to take a user's topic and break it down into exactly {{numConcepts}} essential educational components.\n\nRules:\n- Determine the best visual layout for the topic from these three options: Flat-Lay (for objects), Comic-Grid (for actions/verbs), or Diagram-Grid (for abstract/science concepts).\n- The term should be the core concept name.\n- The definition should be a concise summary of what this term means. This definition provides context to an AI image generator that will later draw it.\n\nJSON Schema to Output:\n{\n  \"title\": \"String (A clean title)\",\n  \"layout_style\": \"String (Flat-Lay, Comic-Grid, or Diagram-Grid)\",\n  \"items\": [\n    {\n      \"number\": \"Integer (1-20)\",\n      \"term\": \"String (The name of the item/concept)\",\n      \"definition\": \"String (A short conversational explanation of the concept)\"\n    }\n  ]\n}\n\n{{role \"user\"}}\nGenerate the educational breakdown for the topic: {{topic}}\n",
            "timeouts": null,
            "update_time": "2026-03-06T23:39:10.455278Z"
          },
          "sensitive_attributes": [],
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxMjAwMDAwMDAwMDAwLCJkZWxldGUiOjEyMDAwMDAwMDAwMDAsInVwZGF0ZSI6MTIwMDAwMDAwMDAwMH19"
        }
