rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    // Check if the user's email exists in the Admins collection
    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/Admins/$(request.auth.token.email));
    }

    // Admins List: Now securely locked to Read-Only.
    match /Admins/{emailId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Curriculum: Anyone authenticated can read. Only admins can write.
    match /Curriculum/{missionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // FlashcardDecks: Full Decks of generated content.
    match /FlashcardDecks/{deckId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isAuthenticated() && (request.resource.data.owner_id == request.auth.uid || resource.data.owner_id == request.auth.uid);
      allow delete: if isAuthenticated() && resource.data.owner_id == request.auth.uid;
      allow write: if isAdmin();
    }

    // ActivityLogs: Admins can read and write system logs.
    match /ActivityLogs/{logId} {
      allow read, write: if isAdmin();
    }

    // Flashcards (Shared Pool): Auth users can read. Only admins can delete/modify existing.
    // Allow users to create if it doesn't exist (e.g. via AI generation save).
    match /Flashcards/{cardId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Users: Users can read/update their own profiles.
    // Relaxed for Mock Billing: Allowing users to update their own energy_bolts directly from the client.
    match /Users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();

      // Subcollection for tracking highest scores per deck
      match /User_Scores/{scoreId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // User_Progress: Users can read/write their own SRS tracking.
    match /User_Progress/{progressId} {
      // Assuming progressId contains the userId, or we enforce it
      allow read, write: if isAuthenticated() && progressId.matches(request.auth.uid + '.*');
    }
  }
}
