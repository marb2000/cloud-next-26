rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Images generated and saved to the shared pool
    match /flashcards/{imageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                    && request.resource.contentType.matches('image/.*');
      allow delete, update: if request.auth != null && request.auth.token.admin == true;
    }

    // Temporary image drafts uploaded during deck creation
    match /drafts/{imageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                    && request.resource.contentType.matches('image/.*');
      allow delete, update: if request.auth != null && request.auth.uid == resource.metadata.ownerId; // Optional future scoping
    }

    // Art associated with specific concepts
    match /concept-art/{imageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                    && request.resource.contentType.matches('image/.*');
      allow delete, update: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
