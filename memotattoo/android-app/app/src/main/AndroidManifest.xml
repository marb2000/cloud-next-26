<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
    The <application> tag is a container for all the components of your application.
    The attributes here are like global settings for your app.

    - android:icon: Sets the default icon for your app.
    - android:label: Sets the default name for your app (pointing to a string resource).
    - android:theme: Sets the default visual theme for your app.
    -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <!--
        This declares a single screen (an Activity) in your app. Every screen must be declared here.

        - android:name: The Kotlin class that implements this activity.
        - android:exported: "true" means this activity can be launched by components outside your app (like the OS itself).
        -->
        <activity
            android:name="com.firebaseailogic.memotattoo.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <!--
            This is the "doorbell" for your app. It tells the Android OS what this activity's purpose is.
            -->
            <intent-filter>
                <!-- This action declares this activity as the main entry point of the app. -->
                <action android:name="android.intent.action.MAIN" />

                <!-- This category makes the activity appear in the device's app launcher. -->
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>